generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  avatarUrl String?
  createdAt DateTime @default(now())

  boardMembers BoardMember[]
  cardMembers  CardMember[]
  comments     Comment[]

  @@map("members")
}

model Board {
  id              String   @id @default(cuid())
  title           String
  backgroundColor String   @default("ocean")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lists   List[]
  labels  Label[]
  members BoardMember[]

  @@map("boards")
}

model BoardMember {
  id       String @id @default(cuid())
  boardId  String
  memberId String
  role     String @default("MEMBER") // "OWNER" | "MEMBER"

  board  Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([boardId, memberId])
  @@index([boardId])
  @@index([memberId])
  @@map("board_members")
}

model List {
  id        String   @id @default(cuid())
  boardId   String
  title     String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
  @@index([boardId, position])
  @@map("lists")
}

model Card {
  id          String    @id @default(cuid())
  listId      String
  title       String
  description String?
  position    Int
  dueDate     DateTime?
  isArchived  Boolean   @default(false)
  coverColor  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  list           List            @relation(fields: [listId], references: [id], onDelete: Cascade)
  labels         CardLabel[]
  checklistItems ChecklistItem[]
  members        CardMember[]
  comments       Comment[]

  @@index([listId])
  @@index([listId, position])
  @@map("cards")
}

model Label {
  id      String @id @default(cuid())
  boardId String
  title   String @default("")
  color   String // hex color

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]

  @@index([boardId])
  @@map("labels")
}

model CardLabel {
  id      String @id @default(cuid())
  cardId  String
  labelId String

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([cardId, labelId])
  @@index([cardId])
  @@index([labelId])
  @@map("card_labels")
}

model ChecklistItem {
  id          String  @id @default(cuid())
  cardId      String
  title       String
  isCompleted Boolean @default(false)
  position    Int

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([cardId, position])
  @@map("checklist_items")
}

model CardMember {
  id       String @id @default(cuid())
  cardId   String
  memberId String

  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([cardId, memberId])
  @@index([cardId])
  @@index([memberId])
  @@map("card_members")
}

model Comment {
  id        String   @id @default(cuid())
  cardId    String
  memberId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([memberId])
  @@map("comments")
}
